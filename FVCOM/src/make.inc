#===============================================================================
# FVCOM make.inc - Windows MSYS2 CI Final Stable
#===============================================================================

#------------------------------------------------------------------------------
# Compilers
#------------------------------------------------------------------------------

FC      = gfortran
CC      = gcc
CXX     = g++

#------------------------------------------------------------------------------
# Compiler Flags
#------------------------------------------------------------------------------

FFLAGS  = -O3 -cpp -fallow-argument-mismatch -ffree-line-length-none -fno-range-check
CFLAGS  = -O3

#------------------------------------------------------------------------------
# Preprocessor Definitions
#------------------------------------------------------------------------------

DEFS = -DGFORTRAN -DDOUBLE_PRECISION -DWET_DRY -DMETIS_5

#------------------------------------------------------------------------------
# Include Paths
#------------------------------------------------------------------------------

INCS = -I./libs/julian -I/mingw64/include

#------------------------------------------------------------------------------
# Libraries
#------------------------------------------------------------------------------

LIBS = -L./libs/julian -ljulian \
       -lmetis \
       -lnetcdff \
       -lnetcdf